// Prisma schema for blessing
// Migrated from kh-server TypeORM entities

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostTag {
  worship
  prayer
  life
  faith
  mission
  youth
  free
}

model Church {
  id        Int     @id @default(autoincrement())
  name      String
  address   String?
  city      String?
  district  String?
  phone     String?
  pastor_nm String?
  lat       Float?
  lon       Float?
  source    String?

  users     User[]

  @@index([name])
  @@index([city])
  @@map("churches")
}

model User {
  id                     Int       @id @default(autoincrement())
  username               String    @unique
  email                  String    @unique
  password               String
  affiliation            String?   @db.VarChar(255)
  church_id              Int?
  church                 Church?   @relation(fields: [church_id], references: [id], onDelete: SetNull)
  points                 Int       @default(0)
  last_login_reward_date String?   @db.VarChar(10)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  posts             Post[]
  comments          Comment[]
  likes             Like[]
  affiliation_posts AffiliationPost[]
  events            Event[]

  sent_messages     Message[] @relation("MessageSender")
  received_messages Message[] @relation("MessageReceiver")
  verify_requests   ChurchVerifyRequest[]

  following         Follow[] @relation("Follower")
  followers         Follow[] @relation("Followee")
  blocks_made       Block[]  @relation("Blocker")
  blocks_received   Block[]  @relation("Blocked")
  reports_made      Report[] @relation("Reporter")

  @@index([church_id])
}

model Post {
  id           Int      @id @default(autoincrement())
  title        String
  content      String   @db.Text
  views        Int      @default(0)
  tag          PostTag  @default(free)
  images       String[] @default([])
  is_anonymous Boolean  @default(false)
  created_at   DateTime @default(now())

  author_id Int
  author    User @relation(fields: [author_id], references: [id], onDelete: Cascade)

  comments Comment[]
  likes    Like[]

  @@index([author_id])
  @@index([tag])
  @@index([is_anonymous])
  @@index([created_at])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  cover       String?
  date_text   String
  location    String?
  host        String?
  ppl         Int      @default(0)
  price       String?
  tag         String?
  tag_color   String?
  featured    Boolean  @default(false)
  start_at    DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author_id Int
  author    User @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([author_id])
  @@index([featured])
  @@index([start_at])
  @@index([created_at])
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  created_at DateTime @default(now())

  author_id Int
  author    User @relation(fields: [author_id], references: [id], onDelete: Cascade)

  post_id Int
  post    Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  parent_id Int?
  parent    Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([post_id])
  @@index([author_id])
  @@index([parent_id])
}

model Like {
  id Int @id @default(autoincrement())

  post_id Int
  post    Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  user_id Int
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([post_id, user_id])
  @@index([post_id])
  @@index([user_id])
}

model AnonymousPost {
  id         Int      @id @default(autoincrement())
  title      String
  content    String   @db.Text
  ip_address String
  views      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  comments AnonymousComment[]
  likes    AnonymousLike[]

  @@index([created_at])
}

model AnonymousComment {
  id         String   @id @default(uuid())
  content    String
  ip_address String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  post_id Int
  post    AnonymousPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  parent_id String?
  parent    AnonymousComment?  @relation("AnonCommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies   AnonymousComment[] @relation("AnonCommentReplies")

  @@index([post_id])
  @@index([parent_id])
}

model AnonymousLike {
  id         Int    @id @default(autoincrement())
  ip_address String

  post_id Int
  post    AnonymousPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, ip_address])
  @@index([post_id])
}

model AffiliationPost {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  views       Int      @default(0)
  affiliation String?  @db.VarChar(255)
  images      String[] @default([])
  created_at  DateTime @default(now())

  author_id Int
  author    User @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@index([author_id])
  @@index([affiliation])
  @@index([created_at])
}

model Message {
  id         Int       @id @default(autoincrement())
  content    String    @db.Text
  created_at DateTime  @default(now())
  read_at    DateTime?

  sender_id   Int
  sender      User @relation("MessageSender", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver_id Int
  receiver    User @relation("MessageReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@index([sender_id])
  @@index([receiver_id])
  @@index([created_at])
  @@index([sender_id, receiver_id, created_at])
  @@index([receiver_id, sender_id, created_at])
}

model ChurchVerifyRequest {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  church_id   Int?
  church_name String
  role        String
  method      String
  // pending | approved | rejected
  status      String   @default("pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

model Follow {
  id           Int      @id @default(autoincrement())
  follower_id  Int
  follower     User     @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  followee_id  Int
  followee     User     @relation("Followee", fields: [followee_id], references: [id], onDelete: Cascade)
  created_at   DateTime @default(now())

  @@unique([follower_id, followee_id])
  @@index([follower_id])
  @@index([followee_id])
}

model Block {
  id          Int      @id @default(autoincrement())
  blocker_id  Int
  blocker     User     @relation("Blocker", fields: [blocker_id], references: [id], onDelete: Cascade)
  blocked_id  Int
  blocked     User     @relation("Blocked", fields: [blocked_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@unique([blocker_id, blocked_id])
  @@index([blocker_id])
  @@index([blocked_id])
}

model Report {
  id          Int      @id @default(autoincrement())
  reporter_id Int
  reporter    User     @relation("Reporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  // "user" | "post" | "comment"
  target_type String
  target_id   Int
  // "spam" | "harassment" | "inappropriate" | "impersonation" | "other"
  reason      String
  note        String?  @db.Text
  // pending | reviewed | dismissed
  status      String   @default("pending")
  created_at  DateTime @default(now())

  @@index([reporter_id])
  @@index([target_type, target_id])
  @@index([status])
  @@index([created_at])
}
