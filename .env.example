# ============================================================
# Database
# ============================================================
# Stage (Synology Docker): postgres on the same docker network
# DATABASE_URL="postgresql://blessing:blessing@db:5432/blessing?schema=public"
#
# Local dev (host machine):
# DATABASE_URL="postgresql://blessing:blessing@localhost:5432/blessing?schema=public"
#
# Production (Supabase):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DATABASE_URL=

# ============================================================
# Auth
# ============================================================
NEXTAUTH_SECRET=please-change-me
# NEXTAUTH_URL=http://localhost:3000

# JWT for backend-style auth (migrated from kh-server)
JWT_SECRET=please-change-me

# ============================================================
# OAuth — 소셜 로그인 (미설정 시 해당 버튼 비활성)
# ============================================================

# Google OAuth: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao OAuth: https://developers.kakao.com/
# 앱 설정 → 카카오 로그인 → Redirect URI: {NEXTAUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Naver OAuth: https://developers.naver.com/apps/
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================================
# SEO / Metadata
# ============================================================
# 사이트의 퍼블릭 URL — canonical/sitemap/robots/OG 에 쓰임
# 예) https://blessing.synology.me
NEXT_PUBLIC_SITE_URL=

# ============================================================
# External upload (Synology NAS)
# ============================================================
# UPLOAD_BASE_URL=

# ============================================================
# Google AdSense (선택)
# 설정하면 좌우 광고 슬롯 + head 스크립트가 자동 활성화됨
# ============================================================
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ============================================================
# Legacy — Phase 4 포팅 완료 후 사용되지 않음 (안전하게 빈 값 유지)
# ============================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_PRODUCTION_API_BASE_URL=
