# ============================================================
# Database
# ============================================================
# Stage (Synology Docker): postgres on the same docker network
# DATABASE_URL="postgresql://blessing:blessing@db:5432/blessing?schema=public"
#
# Local dev (host machine):
# DATABASE_URL="postgresql://blessing:blessing@localhost:5432/blessing?schema=public"
#
# Production (Supabase):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DATABASE_URL=

